# Frontend runtime config
# In dev: `npm run dev` will proxy `/api/*` to `CALCULATIETOOL_BACKEND_INTERNAL_URL` via `src/app/api/[...path]/route.ts`.

# Optional: override where the Next.js proxy forwards requests.
CALCULATIETOOL_BACKEND_INTERNAL_URL=http://localhost:8000/api

# Optional: force the API base URL used by client code (defaults to /api).
# NEXT_PUBLIC_API_BASE_URL=/api

